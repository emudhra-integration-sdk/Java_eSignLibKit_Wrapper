# ─────────────────────────────────────────────────────────────────────────────
# local.properties.example
#
# Copy this file to local.properties and fill in the paths for your machine.
# local.properties is listed in .gitignore and is never committed to git.
# ─────────────────────────────────────────────────────────────────────────────

# Path to the compiled eMudhra eSign SDK JAR.
# Build it from: https://github.com/emudhraltd/java-esign-sdk
# Then point this to the built JAR, e.g.:
#   ../java-esign-sdk-main/dist/eSignASPLibrary5_5.jar
file.reference.eSignASPLibrary5_10.jar=../java-esign-sdk-main/dist/eSignASPLibrary5_5.jar

# Open-source dependency JARs.
# These are in the lib/ folder of this repo after running scripts/download-deps.ps1
# or scripts/download-deps.sh  (or copy them from the SDK project's lib/ folder).
file.reference.batik-all-1.13.jar=lib/batik-all-1.13.jar
file.reference.commons-io-2.4.jar=lib/commons-io-2.4.jar
file.reference.org.w3c.dom.svg-1.1.0.jar=lib/org.w3c.dom.svg-1.1.0.jar
file.reference.xmlgraphics-commons-2.4.jar=lib/xmlgraphics-commons-2.4.jar
file.reference.gson-2.8.5.jar=lib/gson-2.8.5.jar

# Java 8 compiler (only needed if javac is not on your PATH)
# javac.executable=C:/Program Files/Java/jdk1.8.0_202/bin/javac
